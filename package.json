{
  "name": "effect-libreoffice-workspace",
  "private": true,
  "type": "module",
  "version": "2.0.0-dev",
  "scripts": {
    "build": "pnpm -r build",
    "build:docker": "docker build -f apps/server/Dockerfile -t fiws/libre-convert .",
    "test": "vitest run",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "generate-docs": "typedoc",
    "format-fix": "biome format --write"
  },
  "repository": {
    "url": "https://github.com/fiws/effect-libreoffice"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
