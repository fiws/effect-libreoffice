{
  "name": "effect-libreoffice-workspace",
  "private": true,
  "type": "module",
  "version": "2.0.0-dev",
  "scripts": {
    "build": "pnpm -r build",
    "build:docker": "docker build -f apps/server/Dockerfile -t fiws/libre-convert .",
    "test": "vitest run",
    "bench": "vitest bench",
    "type-check": "tsc --noEmit",
    "generate-docs": "typedoc",
    "format-fix": "biome format --write"
  },
  "repository": {
    "url": "https://github.com/fiws/effect-libreoffice"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.28.0",
    "effect": "^3.20.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
